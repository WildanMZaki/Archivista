#include <windows.h>
#include "@CMAKE_SOURCE_DIR@/Header/resource.h"

IDI_ICON1 ICON "@CMAKE_SOURCE_DIR@/assets/app.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS VOS__WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE VFT2_UNKNOWN

BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904E4"
        BEGIN
            VALUE "CompanyName",      "Archivista\0"
            VALUE "FileDescription",  "Text Editor\0"
            VALUE "FileVersion",      "@PROJECT_VERSION@\0"
            VALUE "InternalName",     "Archivista.exe\0"
            VALUE "OriginalFilename", "Archivista.exe\0"
            VALUE "ProductName",      "Archivista\0"
            VALUE "ProductVersion",   "@PROJECT_VERSION@\0"
        END
    END

    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END